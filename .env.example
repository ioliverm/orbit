# Orbit — local development environment (Slice 0a per ADR-015).
#
# Copy to `.env` and fill in real values:
#     cp .env.example .env
#     chmod 600 .env                     # S0-19 local flavor — do not skip
#     $EDITOR .env                        # fill in passwords
#
# `.env` is git-ignored by repo-root `.gitignore`. NEVER commit it.
# NEVER paste the contents into a log, an issue, a chat, or a screenshot.
# In 0b this file is replaced by systemd `LoadCredential=` from a 0600 file
# owned by the `orbit` user — see ADR-013 §Secrets and ADR-015 S0-19 row.
#
# All three Postgres role passwords are required before `just db-up` can
# succeed — docker-compose.yaml uses `${VAR:?msg}` syntax to fail loudly if
# any are missing.

# -------------------------------------------------------------------------
# Postgres — init-time credentials
# -------------------------------------------------------------------------

# Bootstrap superuser. Only used by the container's initdb phase and by the
# first-boot init scripts. Application code must NEVER connect as this user.
# Generate: `openssl rand -base64 32`
POSTGRES_PASSWORD=CHANGE_ME_superuser_password

# Role passwords consumed by scripts/dev/pg_init/00-render-roles.sh during
# the first-boot init. Rotate by wiping the volume (`just db-reset`) and
# re-applying; 0b introduces proper rotation without rebuild.
# Generate each: `openssl rand -base64 32`
POSTGRES_ORBIT_MIGRATE_PASSWORD=CHANGE_ME_migrate_password
POSTGRES_ORBIT_APP_PASSWORD=CHANGE_ME_app_password
POSTGRES_ORBIT_SUPPORT_PASSWORD=CHANGE_ME_support_password

# -------------------------------------------------------------------------
# Postgres — connection strings (consumed by backend + sqlx-cli)
# -------------------------------------------------------------------------

# Application runtime connection. `orbit_app` has NO BYPASSRLS and NO
# superuser — every query is subject to RLS. `sslmode=verify-full` enforces
# TLS with hostname + certificate verification against the self-signed cert
# generated by scripts/dev/pg_init/02-tls.sh.
#
# After `just db-up`, copy the cert with:
#     just db-cert
# which drops it at `scripts/dev/.server.crt` (git-ignored).
DATABASE_URL=postgres://orbit_app:CHANGE_ME_app_password@127.0.0.1:5432/orbit?sslmode=verify-full&sslrootcert=scripts/dev/.server.crt

# Migration-only connection (owns schema). Used by `sqlx migrate run`.
DATABASE_URL_MIGRATE=postgres://orbit_migrate:CHANGE_ME_migrate_password@127.0.0.1:5432/orbit?sslmode=verify-full&sslrootcert=scripts/dev/.server.crt

# Read-only support connection (optional for local work; wire up when the
# audit-log flow is scaffolded — Slice 1 T6).
# DATABASE_URL_SUPPORT=postgres://orbit_support:CHANGE_ME_support_password@127.0.0.1:5432/orbit?sslmode=verify-full&sslrootcert=scripts/dev/.server.crt

# -------------------------------------------------------------------------
# Backend runtime
# -------------------------------------------------------------------------

# `tracing-subscriber` EnvFilter. `info` is the dev default; use `debug` for
# more verbose output on a specific crate:
#     RUST_LOG=info,orbit_api=debug
RUST_LOG=info

# -------------------------------------------------------------------------
# Reminders
# -------------------------------------------------------------------------
#
# 1. `chmod 600 .env` — required by S0-19 local flavor.
# 2. Do NOT share `.env`. Do NOT commit it. Do NOT paste its values anywhere.
# 3. Re-generate any password that has ever been pasted into a chat, terminal
#    recording, ticket, or screenshot — treat it as compromised.
