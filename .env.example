# Orbit — local development environment (Slice 0a per ADR-015).
#
# Copy to `.env` and fill in real values:
#     cp .env.example .env
#     chmod 600 .env                     # S0-19 local flavor — do not skip
#     $EDITOR .env                        # fill in passwords
#
# `.env` is git-ignored by repo-root `.gitignore`. NEVER commit it.
# NEVER paste the contents into a log, an issue, a chat, or a screenshot.
# In 0b this file is replaced by systemd `LoadCredential=` from a 0600 file
# owned by the `orbit` user — see ADR-013 §Secrets and ADR-015 S0-19 row.
#
# All three Postgres role passwords are required before `just db-up` can
# succeed — docker-compose.yaml uses `${VAR:?msg}` syntax to fail loudly if
# any are missing.

# -------------------------------------------------------------------------
# Postgres — init-time credentials
# -------------------------------------------------------------------------

# Bootstrap superuser. Only used by the container's initdb phase and by the
# first-boot init scripts. Application code must NEVER connect as this user.
# Generate: `openssl rand -base64 32`
POSTGRES_PASSWORD=CHANGE_ME_superuser_password

# Role passwords consumed by scripts/dev/pg_init/00-render-roles.sh during
# the first-boot init. Rotate by wiping the volume (`just db-reset`) and
# re-applying; 0b introduces proper rotation without rebuild.
# Generate each: `openssl rand -base64 32`
POSTGRES_ORBIT_MIGRATE_PASSWORD=CHANGE_ME_migrate_password
POSTGRES_ORBIT_APP_PASSWORD=CHANGE_ME_app_password
POSTGRES_ORBIT_SUPPORT_PASSWORD=CHANGE_ME_support_password

# -------------------------------------------------------------------------
# Postgres — connection strings (consumed by backend + sqlx-cli)
# -------------------------------------------------------------------------

# Application runtime connection. `orbit_app` has NO BYPASSRLS and NO
# superuser — every query is subject to RLS.
#
# TLS posture for 0a is `sslmode=require` — encryption is enforced, but
# the client does not verify the cert chain against a trust anchor.
# Rationale: the dev Postgres is a loopback-bound container we control
# both ends of, served by a self-signed cert from a dev CA (see
# scripts/dev/gen-tls-cert.sh); rustls rejects the dev cert under
# verify-full even though it's structurally valid. 0b uses Let's Encrypt
# over real DNS where verify-full is trivial — flip this param then.
#
# If you want to attempt verify-full anyway, `just db-up` copies the dev
# CA to scripts/dev/.ca.crt and the URL becomes:
#   sslmode=verify-full&sslrootcert=scripts/dev/.ca.crt
# (Currently rejected by sqlx's rustls TLS stack — known issue.)
DATABASE_URL=postgres://orbit_app:CHANGE_ME_app_password@127.0.0.1:5432/orbit?sslmode=require

# Migration-only connection (owns schema). Used by `sqlx migrate run`.
DATABASE_URL_MIGRATE=postgres://orbit_migrate:CHANGE_ME_migrate_password@127.0.0.1:5432/orbit?sslmode=require

# Read-only support connection (optional for local work; wire up when the
# audit-log flow is scaffolded — Slice 1 T6).
# DATABASE_URL_SUPPORT=postgres://orbit_support:CHANGE_ME_support_password@127.0.0.1:5432/orbit?sslmode=require

# -------------------------------------------------------------------------
# Backend runtime
# -------------------------------------------------------------------------

# `tracing-subscriber` EnvFilter. `info` is the dev default; use `debug` for
# more verbose output on a specific crate:
#     RUST_LOG=info,orbit_api=debug
RUST_LOG=info

# Emit `Secure` on session cookies. The shipped binary defaults to `true`
# (production posture); local dev runs over plain HTTP on localhost:5173
# and so must explicitly opt out — browsers drop `Secure` cookies on HTTP
# origins. Flip back to `true` (or delete the line) once the stack is on
# TLS end-to-end (Slice 8).
APP_COOKIE_SECURE=false

# 64-hex-char (32-byte) HMAC-SHA256 key used to derive `audit_log.ip_hash`
# and `sessions.ip_hash` (SEC-054). Stable per installation so the hashes
# are join-able across rows but raw IPs never hit disk. Generate once:
#     openssl rand -hex 32
# Rotating the key invalidates prior ip_hash joins (no on-the-fly rekey in
# Slice 1); ADR-015 §0b covers the rotation path.
APP_IP_HASH_KEY_HEX=CHANGE_ME_64_hex_chars_generated_via_openssl_rand_hex_32

# -------------------------------------------------------------------------
# Reminders
# -------------------------------------------------------------------------
#
# 1. `chmod 600 .env` — required by S0-19 local flavor.
# 2. Do NOT share `.env`. Do NOT commit it. Do NOT paste its values anywhere.
# 3. Re-generate any password that has ever been pasted into a chat, terminal
#    recording, ticket, or screenshot — treat it as compromised.
